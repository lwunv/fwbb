TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# REQUIRED in production. Generate via: openssl rand -hex 32
JWT_SECRET=change-me-to-random-32-byte-hex
USER_COOKIE_SECRET=change-me-to-random-32-byte-hex
CRON_SECRET=change-me-to-random-hex

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Facebook Login (REQUIRED for member login flow)
NEXT_PUBLIC_FB_APP_ID=your-fb-app-id
# App Secret từ Facebook Developer Console (App Settings → Basic).
# BẮT BUỘC để verify access token qua /debug_token. KHÔNG commit value thật.
FB_APP_ID=your-fb-app-id
FB_APP_SECRET=your-fb-app-secret
FB_PAGE_ACCESS_TOKEN=
FB_MESSENGER_GROUP_THREAD_ID=

# Google Login (OAuth alternative to Facebook). Lấy ở Google Cloud Console:
# APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Add authorized origins: https://your-domain.com (+ http://localhost:8888 cho dev).
# KHÔNG cần client secret cho web flow — chỉ public client id.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gmail Pub/Sub (REQUIRED nếu dùng bank webhook auto-match)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/your-topic
GMAIL_PUSH_WEBHOOK_SECRET=change-me-to-random-hex
PUBSUB_OIDC_AUDIENCE=https://your-domain.vercel.app/api/webhooks/gmail
PUBSUB_OIDC_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

# Timo / VietQR
NEXT_PUBLIC_TIMO_BANK_BIN=970454
NEXT_PUBLIC_TIMO_ACCOUNT_NO=
NEXT_PUBLIC_TIMO_ACCOUNT_NAME=

# --- Password reset email (SMTP, e.g. Gmail App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-bot@gmail.com
# Gmail: create at https://myaccount.google.com/apppasswords (needs 2FA enabled)
SMTP_PASS=your-16-char-app-password
MAIL_FROM=FWBB <your-bot@gmail.com>
# Canonical https origin used to build the reset link (NOT derived from Host header)
APP_BASE_URL=https://your-domain
